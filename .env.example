# Anthropic API key (required)
ANTHROPIC_API_KEY=sk-ant-...

# WyScout API credentials (optional — tool degrades gracefully if missing)
WYSCOUT_USERNAME=
WYSCOUT_PASSWORD=

# Path to parquet data files (default: ./data)
DATA_DIR=./data

# API key to protect endpoints (optional — no auth if empty)
API_KEY=

# Default model for complex queries (override via router)
DEFAULT_MODEL=claude-opus-4-0

# Fast model used for request classification
ROUTER_MODEL=claude-haiku-4-0
